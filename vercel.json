{
  "installCommand": "npm install",
  "buildCommand": "npm -w market-ui run build",
  "outputDirectory": "apps/market-ui/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "GRAVITY_API_URL": "https://antigravity.fly.dev"
  }
}
