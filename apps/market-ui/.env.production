# ─────────────────────────────────────────────────
# Market UI — Production (Vercel/Cloud)
# ─────────────────────────────────────────────────
# NOTE: Vercel project env vars are the SOURCE OF TRUTH at build time and
# OVERRIDE anything here. Keep this file free of secrets — VITE_* values are
# bundled into the browser bundle and are therefore PUBLIC.
#
# Data-provider keys (Tavily, Alpha Vantage, LLMs) live server-side as Fly
# secrets on market-server / gravity-api and are never exposed to the client.

# ── API Endpoints (set in Vercel env) ──
# VITE_API_URL=https://market-server-prod.fly.dev
# VITE_GRAVITY_API_URL=https://gravity-api-prod.fly.dev

# ── Auth ──
# Production runs Supabase auth. (The Vercel env var VITE_AUTH_BACKEND=supabase
# is authoritative; this line documents the real value to avoid confusion.)
VITE_AUTH_BACKEND=supabase
VITE_DEV_AUTH_BYPASS=false

# ── Supabase (anon key is public by design) ──
VITE_SUPABASE_URL=https://ueuznqilkhyszhgbmpyk.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_VA5WT8uZBRYb54U1sJG51g_LAf4nF8H

# ⛔ No data-provider/LLM keys here. Tavily + Alpha Vantage are proxied through
#    market-server (server-side TAVILY_API_KEY / ALPHA_VANTAGE_API_KEY).
